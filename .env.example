ENVIRONMENT=development
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173,http://localhost

POSTGRES_DB=vpnbotx
POSTGRES_USER=vpnbotx
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://vpnbotx:change-me@postgres:5432/vpnbotx
SYNC_DATABASE_URL=postgresql+psycopg://vpnbotx:change-me@postgres:5432/vpnbotx
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-a-long-random-secret-before-production
CREDENTIALS_ENCRYPTION_KEY=replace-with-fernet-key
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SUBSCRIPTION_PUBLIC_BASE_URL=http://localhost

VITE_API_BASE_URL=/api
